# Copiar a .env y completar con valores reales
# NUNCA subir .env a git

# ── Hyperliquid ────────────────────────────────────────────────────────────────
HYPERLIQUID_PRIVATE_KEY=0xTU_CLAVE_PRIVADA_EVM
# Opcional: si está seteada, las órdenes van a la subcuenta vía vaultAddress.
# Si está vacía o comentada, opera en la cuenta principal.
HYPERLIQUID_SUBACCOUNT_ADDRESS=0xDIRECCION_SUBCUENTA
HYPERLIQUID_NETWORK=testnet

# ── Capital por nivel (USDC) ───────────────────────────────────────────────────
CAPITAL_PER_LEVEL=900.0
MAX_CAPITAL_USDC=5400.0

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=1234567890
